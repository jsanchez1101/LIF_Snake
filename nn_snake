import pygame
from collections import deque
import random

# --- GRID SETTINGS ---
# the game world is a grid of cells, each cell is GRID_SIZE pixels wide/tall
GRID_SIZE = 20
GRID_WIDTH = 30   # 30 cells across
GRID_HEIGHT = 20  # 20 cells tall
WINDOW_WIDTH = GRID_SIZE * GRID_WIDTH   # 600 pixels
WINDOW_HEIGHT = GRID_SIZE * GRID_HEIGHT # 400 pixels

# --- COLORS ---
BLACK = (0, 0, 0)
GREEN = (0, 200, 0)
DARK_GREEN = (0, 150, 0)
RED = (255, 50, 50)
WHITE = (255, 255, 255)

# --- PYGAME SETUP ---
pygame.init()
screen = pygame.display.set_mode((WINDOW_WIDTH, WINDOW_HEIGHT))
pygame.display.set_caption("This is a AI")
clock = pygame.time.Clock()
font = pygame.font.SysFont(None, 36)

def spawn_food(snake):
    """Pick a random grid cell that isn't occupied by the snake."""
    while True:
        pos = (random.randint(0, GRID_WIDTH - 1), random.randint(0, GRID_HEIGHT - 1))
        if pos not in snake:
            return pos

def run_game():
    # --- INITIAL STATE ---
    # snake is a deque of (x, y) grid positions, head is at index 0
    snake = deque([(GRID_WIDTH // 2, GRID_HEIGHT // 2)])
    direction = (1, 0)  # start moving right
    food = spawn_food(snake)
    score = 0
    game_over = False

    while True:
        # --- EVENT HANDLING ---
        # pygame collects all user input as "events" each frame
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                pygame.quit()
                exit()
            elif event.type == pygame.KEYDOWN:
                # change direction, but prevent reversing into yourself
                # e.g. if going right (1,0), can't go left (-1,0)
                if event.key == pygame.K_UP and direction != (0, 1):
                    direction = (0, -1)
                elif event.key == pygame.K_DOWN and direction != (0, -1):
                    direction = (0, 1)
                elif event.key == pygame.K_LEFT and direction != (1, 0):
                    direction = (-1, 0)
                elif event.key == pygame.K_RIGHT and direction != (-1, 0):
                    direction = (1, 0)
                # restart on space after game over
                elif event.key == pygame.K_SPACE and game_over:
                    return True  # signal to restart

        if game_over:
            # --- GAME OVER SCREEN ---
            # draw everything frozen, show score
            screen.fill(BLACK)
            game_over_text = font.render(f"Game Over! Score: {score}", True, WHITE)
            restart_text = font.render("Press SPACE to restart", True, WHITE)
            screen.blit(game_over_text, (WINDOW_WIDTH // 2 - game_over_text.get_width() // 2, WINDOW_HEIGHT // 2 - 30))
            screen.blit(restart_text, (WINDOW_WIDTH // 2 - restart_text.get_width() // 2, WINDOW_HEIGHT // 2 + 10))
            pygame.display.flip()
            clock.tick(10)
            continue  # skip the rest of the loop, wait for input

        # --- MOVEMENT ---
        # new head = current head + direction (move one grid cell)
        new_head = (snake[0][0] + direction[0], snake[0][1] + direction[1])

        # --- COLLISION DETECTION ---
        # hit a wall?
        if (new_head[0] < 0 or new_head[0] >= GRID_WIDTH or
            new_head[1] < 0 or new_head[1] >= GRID_HEIGHT):
            game_over = True
            continue

        # hit yourself?
        if new_head in snake:
            game_over = True
            continue

        # --- UPDATE SNAKE ---
        # add new head to front of deque
        snake.appendleft(new_head)

        # --- FOOD CHECK ---
        if new_head == food:
            # ate food: don't remove tail (snake grows by 1)
            score += 1
            food = spawn_food(snake)
        else:
            # no food: remove tail (snake stays same length, appears to move)
            snake.pop()

        # --- DRAWING ---
        screen.fill(BLACK)

        # draw snake; each segment is a green rectangle
        for i, segment in enumerate(snake):
            rect = pygame.Rect(segment[0] * GRID_SIZE, segment[1] * GRID_SIZE, GRID_SIZE, GRID_SIZE)
            # head is brighter green, body is darker
            color = GREEN if i == 0 else DARK_GREEN
            pygame.draw.rect(screen, color, rect)

        # draw food
        food_rect = pygame.Rect(food[0] * GRID_SIZE, food[1] * GRID_SIZE, GRID_SIZE, GRID_SIZE)
        pygame.draw.rect(screen, RED, food_rect)

        # draw score
        score_text = font.render(f"Score: {score}", True, WHITE)
        screen.blit(score_text, (10, 10))

        # push frame to screen
        pygame.display.flip()

        # 10 frames per second = snake moves 10 times per second
        clock.tick(10)

    return False

# --- MAIN LOOP ---
# allows restarting without relaunching the script
while run_game():
    pass